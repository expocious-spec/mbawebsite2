# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url-here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# Discord OAuth
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_GUILD_ID=your-discord-server-id

# Discord Bot Integration
BOT_SECRET_KEY=your-random-secret-key-here

# Discord Bot API (for minigame completions and other bot notifications)
DISCORD_BOT_API_URL=https://your-bot-api.com

# NextAuth
NEXTAUTH_URL=https://mbaassociation.com
NEXTAUTH_SECRET=your-nextauth-secret-here

# Optional: YouTube API (for live streams)
YOUTUBE_API_KEY=your-youtube-api-key-here
